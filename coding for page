<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Birrieria Estilo Jalisco</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background: #f6f1ea;
    color: #222;
}

/* NAV */
nav {
    position: fixed;
    width: 100%;
    top: 0;
    background: rgba(139,0,0,0.95);
    display: flex;
    justify-content: center;
    padding: 14px;
    z-index: 999;
    backdrop-filter: blur(10px);
}

nav a {
    color: white;
    margin: 0 18px;
    text-decoration: none;
    font-weight: 500;
    transition: 0.3s;
}

nav a:hover {
    opacity: 0.7;
}

/* HERO */
.hero {
    height: 100vh;
    background:
    linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.7)),
    url('https://images.unsplash.com/photo-1600891964599-f61ba0e24092') center/cover;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: white;
    padding: 20px;
}

.hero h1 {
    font-size: 4rem;
    letter-spacing: 1px;
}

.hero p {
    margin-top: 12px;
    font-size: 1.3rem;
    opacity: 0.9;
    max-width: 600px;
}

.hero button {
    margin-top: 25px;
    padding: 14px 30px;
    border: none;
    background: #ff3d00;
    color: white;
    border-radius: 40px;
    font-size: 1rem;
    cursor: pointer;
    transition: 0.3s;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.hero button:hover {
    transform: scale(1.05);
}

/* SECTION */
section {
    padding: 90px 20px;
    max-width: 1150px;
    margin: auto;
}

h2 {
    text-align: center;
    font-size: 2.2rem;
    margin-bottom: 50px;
    color: #8b0000;
}

/* GRID */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 25px;
}

/* CARD */
.card {
    background: white;
    padding: 25px;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    transition: 0.35s ease;
    border-top: 4px solid #8b0000;
}

.card:hover {
    transform: translateY(-10px);
}

/* FEATURE STRIP */
.feature {
    background: linear-gradient(135deg, #8b0000, #b30000);
    color: white;
    padding: 60px 20px;
    text-align: center;
    border-radius: 18px;
}

.feature h3 {
    font-size: 2rem;
}

/* VISIT */
.visit {
    background: #fff3e6;
    padding: 35px;
    border-radius: 16px;
    text-align: center;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}

/* FLOAT CALL BUTTON */
.call {
    position: fixed;
    bottom: 25px;
    right: 25px;
    background: #8b0000;
    color: white;
    padding: 16px 18px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
    box-shadow: 0 15px 35px rgba(0,0,0,0.25);
}

/* FOOTER */
footer {
    background: #8b0000;
    color: white;
    text-align: center;
    padding: 30px;
    margin-top: 60px;
}

/* SMALL ANIMATION */
.card, .hero button {
    animation: fadeUp 0.8s ease;
}

@keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>
</head>

<body>

<!-- NAV -->
<nav>
    <a href="#menu">Menu</a>
    <a href="#breakfast">Breakfast</a>
    <a href="#visit">Visit</a>
</nav>

<!-- HERO -->
<div class="hero">
    <h1>Birrieria Estilo Jalisco</h1>
    <p>Authentic Jalisco-style birria, handmade tortillas, and fresh Mexican food made daily with tradition.</p>
    <button onclick="window.location.href='tel:2105292491'">📞 Order / Call Now</button>
</div>

<!-- MENU -->
<section id="menu">
<h2>🔥 Signature Favorites</h2>
<div class="grid">
    <div class="card"><b>Quesabirria Tacos</b><br>Slow-cooked birria, melted cheese, crispy tortilla</div>
    <div class="card"><b>Birria Ramen</b><br>Rich consommé with noodles & tender beef birria</div>
    <div class="card"><b>Birria Quesadilla</b><br>Handmade tortilla grilled with cheese & birria</div>
    <div class="card"><b>3 Taco Combo</b><br>Three tacos with consommé & sides</div>
</div>
</section>

<!-- FEATURE -->
<section>
<div class="feature">
    <h3>🔥 Family Owned Since 2016</h3>
    <p>Traditional recipes from Jalisco made fresh every day with love and authenticity.</p>
</div>
</section>

<!-- BREAKFAST -->
<section id="breakfast">
<h2>🍳 Breakfast Favorites</h2>
<div class="grid">
    <div class="card">Chorizo & Egg</div>
    <div class="card">Bacon & Egg</div>
    <div class="card">Migas & Egg</div>
    <div class="card">Bean & Cheese</div>
    <div class="card">Ham & Egg</div>
    <div class="card">Nopal & Egg</div>
</div>
</section>

<!-- VISIT -->
<section id="visit">
<h2>📍 Visit Us</h2>
<div class="visit">
    <p><b>13327 Nacogdoches Rd</b><br>San Antonio, Texas 78217</p>
    <p>Tuesday – Sunday: 8:00 AM – 3:00 PM</p>
    <p>Closed Monday</p>
    <p><b>(210) 529-2491</b></p>
</div>
</section>

<!-- CALL BUTTON -->
<a href="tel:2105292491" class="call">📞 Call</a>

<!-- FOOTER -->
<footer>
<p>© 2026 Birrieria Estilo Jalisco • All Rights Reserved</p>
</footer>

</body>
</html>
