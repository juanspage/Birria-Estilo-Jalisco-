<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Birrieria Estilo Jalisco</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background: #faf7f2;
    color: #333;
}

/* HERO */
.hero {
    height: 95vh;
    background: linear-gradient(rgba(0,0,0,0.65), rgba(0,0,0,0.65)),
    url('https://images.unsplash.com/photo-1600891964599-f61ba0e24092') center/cover;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: white;
    text-align: center;
}

.hero h1 {
    font-size: 3.5rem;
}

.hero p {
    margin-top: 10px;
    font-size: 1.2rem;
}

.btn {
    margin-top: 20px;
    padding: 12px 25px;
    background: #ff4500;
    color: white;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    font-size: 1rem;
}

.btn:hover {
    background: #ff6347;
}

/* NAV */
nav {
    position: sticky;
    top: 0;
    background: #8b0000;
    padding: 15px;
    text-align: center;
}

nav a {
    color: white;
    margin: 0 15px;
    text-decoration: none;
}

/* SECTIONS */
section {
    padding: 60px 20px;
    max-width: 1100px;
    margin: auto;
}

h2 {
    text-align: center;
    margin-bottom: 30px;
    color: #8b0000;
}

/* CARDS */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-8px);
}

/* INFO BOX */
.info {
    background: #fff3e6;
    padding: 25px;
    border-radius: 12px;
    text-align: center;
}

/* CALL BUTTON */
.call {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #8b0000;
    color: white;
    padding: 15px 18px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: bold;
}

footer {
    background: #8b0000;
    color: white;
    text-align: center;
    padding: 20px;
}
</style>
</head>

<body>

<nav>
    <a href="#menu">Menu</a>
    <a href="#breakfast">Breakfast</a>
    <a href="#visit">Visit</a>
</nav>

<div class="hero">
    <h1>Birrieria Estilo Jalisco</h1>
    <p>Authentic Jalisco-style birria • Handmade tortillas • Fresh daily food</p>
    <button class="btn" onclick="window.location.href='tel:2105292491'">📞 Call Now</button>
</div>

<section id="menu">
<h2>🔥 Signature Favorites</h2>
<div class="grid">
    <div class="card">Quesabirria Tacos</div>
    <div class="card">Birria Ramen</div>
    <div class="card">Birria Quesadilla</div>
    <div class="card">3 Taco Combo</div>
</div>
</section>

<section id="breakfast">
<h2>🍳 Breakfast</h2>
<div class="grid">
    <div class="card">Chorizo & Egg</div>
    <div class="card">Bacon & Egg</div>
    <div class="card">Migas & Egg</div>
    <div class="card">Bean & Cheese</div>
</div>
</section>

<section id="visit" class="info">
<h2>📍 Visit Us</h2>
<p>13327 Nacogdoches Rd, San Antonio, TX</p>
<p>Tuesday–Sunday: 8AM – 3PM</p>
<p>Closed Monday</p>
</section>

<a href="tel:2105292491" class="call">📞 Call</a>

<footer>
<p>© 2026 Birrieria Estilo Jalisco</p>
</footer>

</body>
</html>
